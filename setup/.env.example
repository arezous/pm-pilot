# PM Operating System - Environment Keys
# Copy this file to the project root: cp setup/.env.example .env
# Then fill in the keys for the services you want to use.

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_GEMINI_API_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# Google Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
